{
  "manifest_version": 3,
  "name": "Meesho Autofill Tool",
  "version": "1.0.0",
  "description": "Meesho Product Catalog Auto-Fill with Profiles",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://supplier.meesho.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://supplier.meesho.com/*"],
      "js": ["combined-content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
